#!/bin/bash
set -e

REGISTRY="docker.upcycleconnect.xyz"
PROJECT="upcycleconnect"
PLATFORM="linux/amd64,linux/arm64"
ROOT="$(cd "$(dirname "$0")" && pwd)"

echo ">>> Login registry"
docker login "$REGISTRY"

echo ">>> Build & push backend"
docker buildx build \
  --platform "$PLATFORM" \
  --push \
  -t "$REGISTRY/$PROJECT/backend:latest" \
  "$ROOT/backend"

echo ">>> Build & push frontend"
docker buildx build \
  --platform "$PLATFORM" \
  --push \
  --build-arg VITE_API_BASE_URL=/api/admin/v1 \
  -t "$REGISTRY/$PROJECT/frontend:latest" \
  "$ROOT/frontend"

echo ">>> Build & push apache"
docker buildx build \
  --platform "$PLATFORM" \
  --push \
  -t "$REGISTRY/$PROJECT/apache:latest" \
  "$ROOT/apache"

echo ""
echo "Toutes les images ont été buildées et pushées sur $REGISTRY"
