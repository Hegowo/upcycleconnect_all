#!/usr/bin/env bash
# =============================================================================
#  upcycleinit — Premier démarrage UpcycleConnect (macOS / Linux)
#  Usage : chmod +x upcycleinit && ./upcycleinit
# =============================================================================
set -euo pipefail

# ── Couleurs ──────────────────────────────────────────────────────────────────
BOLD="\033[1m"
DIM="\033[2m"
GREEN="\033[0;32m"
BGREEN="\033[1;32m"
BLUE="\033[0;34m"
CYAN="\033[0;36m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
RESET="\033[0m"

ok()   { echo -e "  ${GREEN}✔${RESET}  $*"; }
info() { echo -e "  ${CYAN}ℹ${RESET}  $*"; }
warn() { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
fail() { echo -e "  ${RED}✘${RESET}  $*"; exit 1; }
step() { echo -e "\n${BOLD}${BLUE}▶  $*${RESET}"; }

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SQL_FILE="$ROOT/upcycleconnect.sql"
ENV_FILE="$ROOT/.env"
ENV_EXAMPLE="$ROOT/.env.example"
COMPOSE_FILE="$ROOT/docker-compose.yml"

# ── Banner ────────────────────────────────────────────────────────────────────
echo -e ""
echo -e "${BGREEN}  ██╗   ██╗██████╗  ██████╗██╗   ██╗ ██████╗██╗     ███████╗${RESET}"
echo -e "${BGREEN}  ██║   ██║██╔══██╗██╔════╝╚██╗ ██╔╝██╔════╝██║     ██╔════╝${RESET}"
echo -e "${BGREEN}  ██║   ██║██████╔╝██║      ╚████╔╝ ██║     ██║     █████╗  ${RESET}"
echo -e "${BGREEN}  ██║   ██║██╔═══╝ ██║       ╚██╔╝  ██║     ██║     ██╔══╝  ${RESET}"
echo -e "${BGREEN}  ╚██████╔╝██║     ╚██████╗   ██║   ╚██████╗███████╗███████╗${RESET}"
echo -e "${BGREEN}   ╚═════╝ ╚═╝      ╚═════╝   ╚═╝    ╚═════╝╚══════╝╚══════╝${RESET}"
echo -e "${DIM}  UpcycleConnect — Initialisation premier démarrage${RESET}"
echo -e "${DIM}  ─────────────────────────────────────────────────${RESET}\n"

# ── 1. Prérequis ──────────────────────────────────────────────────────────────
step "Vérification des prérequis"

command -v docker &>/dev/null || fail "Docker n'est pas installé. Téléchargez-le sur https://docs.docker.com/get-docker/"
ok "Docker trouvé : $(docker --version | head -1)"

# docker compose (plugin v2) ou docker-compose (v1)
if docker compose version &>/dev/null 2>&1; then
  COMPOSE="docker compose"
elif command -v docker-compose &>/dev/null; then
  COMPOSE="docker-compose"
else
  fail "Docker Compose n'est pas disponible. Installez Docker Desktop ou le plugin Compose."
fi
ok "Compose trouvé : $($COMPOSE version --short 2>/dev/null || $COMPOSE version)"

# Docker daemon actif ?
docker info &>/dev/null 2>&1 || fail "Le démon Docker n'est pas démarré. Lancez Docker Desktop et réessayez."
ok "Démon Docker actif"

[[ -f "$COMPOSE_FILE" ]] || fail "docker-compose.yml introuvable dans $ROOT"
ok "docker-compose.yml présent"

[[ -f "$SQL_FILE" ]] || fail "Fichier SQL introuvable : $SQL_FILE"
ok "Fichier SQL présent : upcycleconnect.sql"

# ── 2. Fichier .env ───────────────────────────────────────────────────────────
step "Configuration de l'environnement"

if [[ ! -f "$ENV_FILE" ]]; then
  [[ -f "$ENV_EXAMPLE" ]] || fail ".env.example introuvable, impossible de créer .env"
  cp "$ENV_EXAMPLE" "$ENV_FILE"
  ok ".env créé à partir de .env.example"
  warn "Vérifiez et personnalisez les valeurs dans .env si nécessaire"
else
  ok ".env déjà présent"
fi

# Lecture des variables .env (ignore les lignes vides / commentaires)
_env_get() {
  local key="$1" default="${2:-}"
  local val
  val=$(grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d '"'"'" | xargs)
  echo "${val:-$default}"
}

DB_ROOT_PASSWORD=$(_env_get "DB_ROOT_PASSWORD" "rootpassword")
DB_DATABASE=$(_env_get "DB_DATABASE" "upcycleconnect")
DB_USERNAME=$(_env_get "DB_USERNAME" "ucadmin")
DB_PASSWORD=$(_env_get "DB_PASSWORD" "strongpassword")
APP_PORT=$(_env_get "APP_PORT" "8080")

info "Base : ${DB_DATABASE}  |  Utilisateur : ${DB_USERNAME}  |  Port app : ${APP_PORT}"

# ── 3. Volume MySQL existant ? ─────────────────────────────────────────────────
step "Vérification des données existantes"

VOLUME_NAME="upcycleconnect_mysql_data"
VOLUME_EXISTS=false
if docker volume inspect "$VOLUME_NAME" &>/dev/null 2>&1; then
  VOLUME_EXISTS=true
  warn "Le volume MySQL '${VOLUME_NAME}' existe déjà."
  echo ""
  echo -e "  ${YELLOW}Que souhaitez-vous faire ?${RESET}"
  echo -e "  ${BOLD}[1]${RESET} Réinitialiser la base (supprime les données existantes) — recommandé pour premier démarrage propre"
  echo -e "  ${BOLD}[2]${RESET} Conserver les données existantes et démarrer seulement les services"
  echo -e "  ${BOLD}[q]${RESET} Quitter"
  echo ""
  read -rp "  Votre choix [1/2/q] : " CHOICE
  case "$CHOICE" in
    1)
      info "Suppression du volume MySQL existant…"
      # Arrêt propre des conteneurs si actifs
      $COMPOSE -f "$COMPOSE_FILE" down --volumes 2>/dev/null || true
      docker volume rm "$VOLUME_NAME" 2>/dev/null || true
      ok "Volume supprimé — réinitialisation propre"
      SKIP_IMPORT=false
      ;;
    2)
      ok "Conservation des données existantes"
      SKIP_IMPORT=true
      ;;
    *)
      echo ""; info "Annulé."; exit 0
      ;;
  esac
else
  ok "Aucune donnée existante — démarrage vierge"
  SKIP_IMPORT=false
fi

# ── 4. Build des images ───────────────────────────────────────────────────────
step "Construction des images Docker"

info "Build en cours… (peut prendre quelques minutes la première fois)"
$COMPOSE -f "$COMPOSE_FILE" build --parallel 2>&1 | \
  grep -E "^(#[0-9]+ |Step |Successfully|=>|ERROR)" || true
ok "Images construites"

# ── 5. Démarrage MySQL ────────────────────────────────────────────────────────
step "Démarrage de MySQL"

$COMPOSE -f "$COMPOSE_FILE" up -d mysql
info "Attente que MySQL soit prêt (jusqu'à 90s)…"

ELAPSED=0
TIMEOUT=90
until docker exec upcycleconnect_mysql mysqladmin ping -h localhost --silent 2>/dev/null; do
  if [[ $ELAPSED -ge $TIMEOUT ]]; then
    fail "MySQL n'a pas démarré après ${TIMEOUT}s. Vérifiez avec : docker logs upcycleconnect_mysql"
  fi
  printf "  ${DIM}. ${RESET}"
  sleep 3
  ELAPSED=$((ELAPSED + 3))
done
echo ""
ok "MySQL est prêt (${ELAPSED}s)"

# ── 6. Import SQL ─────────────────────────────────────────────────────────────
if [[ "$SKIP_IMPORT" == false ]]; then
  step "Import de la base de données"

  info "Import de upcycleconnect.sql en cours…"
  IMPORT_START=$SECONDS

  # Utilise root pour l'import (droits CREATE/DROP nécessaires)
  if docker exec -i upcycleconnect_mysql \
      mysql -u root -p"${DB_ROOT_PASSWORD}" \
      --default-character-set=utf8mb4 \
      "${DB_DATABASE}" < "$SQL_FILE"; then
    IMPORT_DURATION=$((SECONDS - IMPORT_START))
    ok "Import terminé en ${IMPORT_DURATION}s"
  else
    warn "Tentative avec l'utilisateur ${DB_USERNAME}…"
    docker exec -i upcycleconnect_mysql \
      mysql -u "${DB_USERNAME}" -p"${DB_PASSWORD}" \
      --default-character-set=utf8mb4 \
      "${DB_DATABASE}" < "$SQL_FILE" \
      || fail "Échec de l'import SQL. Vérifiez les credentials dans .env"
    ok "Import terminé"
  fi
else
  info "Import ignoré (données conservées)"
fi

# ── 7. Démarrage de tous les services ─────────────────────────────────────────
step "Démarrage de tous les services"

$COMPOSE -f "$COMPOSE_FILE" up -d
ok "Tous les services démarrés"

# ── 8. Vérification finale ────────────────────────────────────────────────────
step "Vérification de l'état des services"

info "Attente de la stabilisation (15s)…"
sleep 15

# État des conteneurs
echo ""
echo -e "  ${BOLD}Conteneurs :${RESET}"
docker ps --format "  {{if eq .Status \"Up\"}}${GREEN}✔${RESET}{{else}}${RED}✘${RESET}{{end}}  {{.Names}}\t{{.Status}}\t{{.Ports}}" \
  --filter "name=upcycleconnect_" 2>/dev/null || \
  docker ps --filter "name=upcycleconnect_" --format "  {{.Names}}\t{{.Status}}\t{{.Ports}}"

# Health check HTTP
echo ""
echo -e "  ${BOLD}Endpoints :${RESET}"
BACKEND_OK=false
FRONTEND_OK=false

if curl -sf --max-time 5 "http://localhost:${APP_PORT}/up" -o /dev/null 2>/dev/null; then
  BACKEND_OK=true
  ok "Backend  → http://localhost:${APP_PORT}/up (OK)"
else
  warn "Backend  → http://localhost:${APP_PORT}/up (pas encore joignable)"
fi

if curl -sf --max-time 5 "http://localhost:${APP_PORT}/" -o /dev/null 2>/dev/null; then
  FRONTEND_OK=true
  ok "Frontend → http://localhost:${APP_PORT}/ (OK)"
else
  warn "Frontend → http://localhost:${APP_PORT}/ (pas encore joignable)"
fi

# ── 9. Résumé ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${DIM}  ─────────────────────────────────────────────────${RESET}"
echo -e "\n${BGREEN}  ✅  UpcycleConnect est prêt !${RESET}\n"
echo -e "  ${BOLD}Accès :${RESET}"
echo -e "    🌐  Application    →  ${CYAN}http://localhost:${APP_PORT}${RESET}"
echo -e "    🔧  Admin panel    →  ${CYAN}http://localhost:${APP_PORT}/admin/login${RESET}"
echo -e "    🗄️   DBGate (DB UI) →  ${CYAN}http://localhost:3000${RESET}  ${DIM}(si port exposé)${RESET}"
echo ""
echo -e "  ${BOLD}Commandes utiles :${RESET}"
echo -e "    ${DIM}Logs en direct  :${RESET}  docker compose logs -f"
echo -e "    ${DIM}Arrêter         :${RESET}  docker compose down"
echo -e "    ${DIM}Redémarrer      :${RESET}  docker compose restart"
echo ""
